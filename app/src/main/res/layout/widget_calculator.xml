<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget layout: one ImageView per button as background,
  overlaid with a TextView for the label.
  RemoteViews supports a limited set of views:
  FrameLayout, LinearLayout, RelativeLayout, GridLayout,
  Button, ImageButton, ImageView, TextView, etc.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp">

    <!-- Widget background -->
    <ImageView
        android:id="@+id/img_widget_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Display area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.5">

            <ImageView
                android:id="@+id/img_display_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:contentDescription="@null" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="end|bottom"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tv_operator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="10sp"
                    android:gravity="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/tv_display"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="normal"
                    android:gravity="end"
                    android:maxLines="1"
                    android:ellipsize="start" />
            </LinearLayout>
        </FrameLayout>

        <!-- Keypad: 5 rows × 4 columns -->
        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button android:id="@+id/btn_c"    style="@style/CalcBtn" android:text="C"   android:layout_weight="1" />
            <Button android:id="@+id/btn_sign" style="@style/CalcBtn" android:text="+/-" android:layout_weight="1" />
            <Button android:id="@+id/btn_pct"  style="@style/CalcBtn" android:text="%"   android:layout_weight="1" />
            <Button android:id="@+id/btn_div"  style="@style/CalcBtn" android:text="÷"   android:layout_weight="1" />
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button android:id="@+id/btn_7"   style="@style/CalcBtn" android:text="7" android:layout_weight="1" />
            <Button android:id="@+id/btn_8"   style="@style/CalcBtn" android:text="8" android:layout_weight="1" />
            <Button android:id="@+id/btn_9"   style="@style/CalcBtn" android:text="9" android:layout_weight="1" />
            <Button android:id="@+id/btn_mul" style="@style/CalcBtn" android:text="×" android:layout_weight="1" />
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button android:id="@+id/btn_4"   style="@style/CalcBtn" android:text="4" android:layout_weight="1" />
            <Button android:id="@+id/btn_5"   style="@style/CalcBtn" android:text="5" android:layout_weight="1" />
            <Button android:id="@+id/btn_6"   style="@style/CalcBtn" android:text="6" android:layout_weight="1" />
            <Button android:id="@+id/btn_sub" style="@style/CalcBtn" android:text="−" android:layout_weight="1" />
        </LinearLayout>

        <!-- Row 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button android:id="@+id/btn_1"   style="@style/CalcBtn" android:text="1" android:layout_weight="1" />
            <Button android:id="@+id/btn_2"   style="@style/CalcBtn" android:text="2" android:layout_weight="1" />
            <Button android:id="@+id/btn_3"   style="@style/CalcBtn" android:text="3" android:layout_weight="1" />
            <Button android:id="@+id/btn_add" style="@style/CalcBtn" android:text="+" android:layout_weight="1" />
        </LinearLayout>

        <!-- Row 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button android:id="@+id/btn_zero" style="@style/CalcBtn" android:text="0" android:layout_weight="2" />
            <Button android:id="@+id/btn_dot"  style="@style/CalcBtn" android:text="." android:layout_weight="1" />
            <Button android:id="@+id/btn_eq"   style="@style/CalcBtn" android:text="=" android:layout_weight="1" />
        </LinearLayout>

    </LinearLayout>
</RelativeLayout>
